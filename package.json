{
  "name": "rental-space-booking",
  "version": "0.1.0",
  "description": "レンタルスペース予約システム — 厳格なDDDをTypeScriptで実装する学習用リポジトリ",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "demo": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build:web": "vite build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  }
}
